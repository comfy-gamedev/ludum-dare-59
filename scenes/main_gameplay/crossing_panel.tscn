[sub_resource type="Shader" id="Shader_iop5q"]
code = "// NOTE: Shader automatically converted from Godot Engine 4.6.2.stable's CanvasItemMaterial.

shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D noise;

void fragment() {
	vec4 c = texture(noise, UV * vec2(0.1 ,1) + vec2(TIME, 0));
	c.rgb = step(1.0 - 2.0 * abs(UV.y - 0.5), c.rgb);
	COLOR = c;
}
"

