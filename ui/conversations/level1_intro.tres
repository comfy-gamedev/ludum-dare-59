[sub_resource type="Resource" id="Resource_0gmtb"]
script = ExtResource("4_yn51q")
side = 1
message = "Uhhh... What are we doing again?"
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_6qm1b"]
script = ExtResource("4_yn51q")
message = "We've been over this two times already!"
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_7i11d"]
script = ExtResource("4_yn51q")
side = 1
character = ExtResource("5_psatb")
message = "I'm still confused too."
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_pcu2o"]
script = ExtResource("4_yn51q")
message = "Ok, one more time, we're almost there."
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_vgi65"]
script = ExtResource("4_yn51q")
message = "The nerds at Command have figured out how to control the Crimson Legion's drones."
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_e1yoy"]
script = ExtResource("4_yn51q")
message = "The drones receive commands from the Legion, using an encryption key."
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_m25q7"]
script = ExtResource("4_yn51q")
message = "We're going to steal that key."
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_b2cds"]
script = ExtResource("4_yn51q")
side = 1
character = ExtResource("5_psatb")
message = "How does that help? Are we gonna have them bash into each other?"
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_t5ll6"]
script = ExtResource("4_yn51q")
side = 1
character = ExtResource("6_yn51q")
message = "We can have them shoot each other."
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_h1esn"]
script = ExtResource("4_yn51q")
message = "Either way, we have to take the key back to Command."
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_65xoq"]
script = ExtResource("4_yn51q")
side = 1
character = ExtResource("7_krjbi")
message = "Why can't I send the signal when we get the key?"
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_wncrj"]
script = ExtResource("4_yn51q")
message = "We don't have the power to reach them all at once. Once they figure out what we're doing, they'll change the key."
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_m8480"]
script = ExtResource("4_yn51q")
side = 1
character = ExtResource("2_8ubwr")
message = "Won't they just do that when we steal the key?"
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_m67gf"]
script = ExtResource("4_yn51q")
message = "Yep, that's why we need to distract them."
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_75nt3"]
script = ExtResource("4_yn51q")
side = 1
character = ExtResource("6_yn51q")
message = "We take out as many as we can and pull their focus away."
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_isi4v"]
script = ExtResource("4_yn51q")
side = 1
character = ExtResource("5_psatb")
message = "We'll slash their drones to pieces!"
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

[sub_resource type="Resource" id="Resource_6gmtd"]
script = ExtResource("4_yn51q")
message = "Exactly. Now get ready, we're here! There shouldn't be too many drones on the way in."
metadata/_custom_type_script = "uid://bh7au0lmg7bca"

